{
  "name": "fitness-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "rimraf .test-dist && tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "check": "npm run lint && npm run typecheck && npm test",
    "test:e2e": "cross-env E2E_MOCK_AI=1 playwright test",
    "test:e2e:ui": "cross-env E2E_MOCK_AI=1 playwright test --ui",
    "ci": "npm run check && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@supabase/ssr": "0.6.1",
    "@supabase/supabase-js": "2.49.4",
    "dotenv": "^16.5.0",
    "next": "15.3.8",
    "openai": "^5.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^20.17.31",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^9.25.1",
    "eslint-config-next": "15.3.1",
    "supabase": "^2.106.0",
    "tailwindcss": "^4",
    "typescript": "^5.8.3",
    "@playwright/test": "1.55.0",
    "cross-env": "^7.0.3",
    "rimraf": "^5.0.1"
  }
}
