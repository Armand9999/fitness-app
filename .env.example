# Public Supabase project configuration. The anon key is safe to expose to the browser
# only when Row Level Security policies are correctly configured in Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public origin used for authentication email redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only OpenAI credential. Never prefix this variable with NEXT_PUBLIC_.
NEXT_APP_OPENAI_API_KEY=your-openai-api-key

# Optional Playwright credentials for authenticated protected-flow E2E tests.
# Use a dedicated non-production test user and never commit real values.
E2E_AUTH_EMAIL=e2e-user@example.com
E2E_AUTH_PASSWORD=replace-with-a-dedicated-test-password
